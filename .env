# talento/.env — no commitear (está en .gitignore)
#
# Público: https://talento.zodiplast.com.ec  (subdominio + dominio raíz)
# Patrón de subida: hikvision/subir_inventario.py (UPLOAD_*).
#
# Scripts que suben por UAPI leen credenciales en:
#   ../hosting_web/.env  →  CPANEL_BASE_URL, CPANEL_USER, CPANEL_API_TOKEN, CPANEL_DOMAIN
# El token de API no es la misma clave que el login web del cPanel.

# --- Destino en el hosting (Talento y cultura) ---
UPLOAD_SUBDOMINIO=talento
UPLOAD_DOMINIO_RAIZ=zodiplast.com.ec
UPLOAD_DIR_REMOTO=public_html/talento

# Login web cPanel (navegador): usuario habitual zodiplas. Completá la clave solo aquí en local;
# los scripts Python usan CPANEL_API_TOKEN en hosting_web/.env (no pegues la clave web en repos).
CPANEL_WEB_USER=zodiplas
CPANEL_WEB_PASSWORD=

# Basic auth en el sitio remoto si un script genera .htpasswd (opcional)
UPLOAD_HTPASS_USER=admin
UPLOAD_HTPASS_PASS=

# Local / legacy FastAPI (legacy/webapp)
AUTH_PASSWORD=

# --- MotherDuck: biometrico → Parquet → nube; luego web en talento.zodiplast.com.ec ---
MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=zodiplast
