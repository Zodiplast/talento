# Copia este archivo a .env y rellena los valores reales.
# El .env NO debe commitearse al repositorio.

# PostgreSQL — mismo servidor compartido que la Intranet
POSTGRES_USER=josue
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=cortana

# Contraseña HTTP Basic Auth para acceder al reporte
# Si se deja vacío o no se define, la app no pide autenticación (solo para desarrollo local)
AUTH_PASSWORD=cambia_esta_clave
